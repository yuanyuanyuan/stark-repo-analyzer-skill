{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stark-repo-analyzer-v1-output-manifest",
  "title": "Stark Repo Analyzer V1 output manifest",
  "type": "object",
  "required": ["schema_version", "status", "analysis_mode", "files"],
  "properties": {
    "schema_version": {"const": 1},
    "status": {"enum": ["awaiting-agent-module-analysis", "complete"]},
    "source_commit": {"type": ["string", "null"]},
    "analysis_mode": {"const": "standard"},
    "graph": {"type": ["object", "null"]},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "bytes": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
